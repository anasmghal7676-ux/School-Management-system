# ═══════════════════════════════════════════════════════════════════
# School Management System — Cloudflare Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
# 1. Copy all variables below into Cloudflare dashboard:
#    Workers & Pages → school-management-system → Settings → Variables and Secrets
# 2. Mark sensitive values (passwords, secrets, keys) as "Secret"
# 3. Set type to "Text" for non-sensitive values
#
# ═══════════════════════════════════════════════════════════════════

# ── Database (Supabase) ─────────────────────────────────────────────
# ⚠️  REQUIRED — Mark as Secret in Cloudflare
DATABASE_URL=postgresql://postgres.[your-project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[your-project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── Authentication (NextAuth) ───────────────────────────────────────
# ⚠️  REQUIRED — Mark as Secret in Cloudflare
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=https://school-management-system.[your-account].workers.dev

# ── App Settings ────────────────────────────────────────────────────
SCHOOL_ID=school_main
SCHOOL_NAME=EduMaster School
NODE_ENV=production

# ── Optional: SMS (Twilio) ──────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Optional: Email (SMTP) ──────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ── Optional: File Storage ──────────────────────────────────────────
# CLOUDFLARE_R2_BUCKET=
# CLOUDFLARE_R2_ACCESS_KEY=
# CLOUDFLARE_R2_SECRET_KEY=
# CLOUDFLARE_ACCOUNT_ID=

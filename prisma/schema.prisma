model Substitution {
  id              String   @id @default(cuid())
  date            DateTime
  timetableId     String?
  absentTeacherId String
  substituteId    String
  classId         String
  sectionId       String?
  subjectId       String?
  period          Int?
  reason          String?
  status          String   @default("Pending") // Pending, Confirmed, Cancelled
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  absentTeacher   Staff    @relation("AbsentTeacher",      fields: [absentTeacherId], references: [id])
  substitute      Staff    @relation("SubstituteTeacher",  fields: [substituteId],    references: [id])
  class           Class    @relation(fields: [classId],    references: [id])
  section         Section? @relation(fields: [sectionId],  references: [id])

  @@index([date])
  @@index([absentTeacherId])
  @@index([substituteId])
}

model ClassPromotion {
  id              String   @id @default(cuid())
  studentId       String
  fromClassId     String
  toClassId       String?
  fromSectionId   String?
  toSectionId     String?
  promotionType   String   // Promoted, Held-Back, Graduated, Transferred
  academicYear    String
  promotedAt      DateTime @default(now())
  promotedBy      String?
  remarks         String?
  createdAt       DateTime @default(now())

  student         Student  @relation(fields: [studentId], references: [id])
  fromClass       Class    @relation("FromClass", fields: [fromClassId], references: [id])
  toClass         Class?   @relation("ToClass",   fields: [toClassId],   references: [id])

  @@index([studentId])
  @@index([academicYear])
  @@index([promotionType])
}

model QuizBank {
  id             String   @id @default(cuid())
  schoolId       String
  title          String
  subjectId      String?
  classId        String?
  duration       Int      @default(30)   // minutes
  totalMarks     Float    @default(100)
  passingMarks   Float    @default(50)
  instructions   String?
  isActive       Boolean  @default(true)
  startTime      DateTime?
  endTime        DateTime?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school         School   @relation(fields: [schoolId], references: [id])
  questions      QuizQuestion[]

  @@index([schoolId])
  @@index([subjectId])
}

model QuizQuestion {
  id             String   @id @default(cuid())
  quizId         String
  questionText   String
  questionType   String   @default("MCQ")  // MCQ, TrueFalse, Short
  optionA        String?
  optionB        String?
  optionC        String?
  optionD        String?
  correctAnswer  String   // A, B, C, D or True/False or text
  marks          Float    @default(1)
  explanation    String?
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())

  quiz           QuizBank @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model IncidentReport {
  id              String   @id @default(cuid())
  schoolId        String
  title           String
  incidentDate    DateTime
  reportedBy      String
  location        String?
  incidentType    String   // Bullying, Fighting, Vandalism, Theft, Misconduct, Accident, Other
  severity        String   @default("Low")  // Low, Medium, High, Critical
  description     String
  witnesses       String?
  actionTaken     String?
  followUpDate    DateTime?
  followUpNotes   String?
  status          String   @default("Open")  // Open, Under-Review, Resolved, Closed
  studentsInvolved String[] // array of student IDs (stored as JSON)
  staffInvolved   String[] // array of staff IDs
  parentNotified  Boolean  @default(false)
  parentNotifiedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school          School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([incidentDate])
  @@index([status])
  @@index([severity])
  @@index([incidentType])
}

model VisitorLog {
  id              String   @id @default(cuid())
  schoolId        String
  visitorName     String
  visitorPhone    String?
  visitorCnic     String?
  purpose         String   // Meeting, Delivery, Interview, Parent, Vendor, Government, Other
  personToMeet    String   // Staff/teacher name
  personToMeetId  String?
  checkIn         DateTime @default(now())
  checkOut        DateTime?
  vehicleNo       String?
  idType          String?  // CNIC, Passport, Driving License
  idNumber        String?
  remarks         String?
  status          String   @default("Checked-In") // Checked-In, Checked-Out
  badgeNumber     String?
  createdAt       DateTime @default(now())

  school          School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([checkIn])
  @@index([status])
}

model ParentTeacherMeeting {
  id              String   @id @default(cuid())
  schoolId        String
  title           String
  meetingDate     DateTime
  startTime       String
  endTime         String
  venue           String?
  classId         String?
  description     String?
  status          String   @default("Scheduled") // Scheduled, Ongoing, Completed, Cancelled
  slots           Int      @default(10) // slots per teacher
  slotDuration    Int      @default(10) // minutes per slot
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school          School   @relation(fields: [schoolId], references: [id])
  appointments    PTMAppointment[]

  @@index([schoolId])
  @@index([meetingDate])
  @@index([status])
}

model PTMAppointment {
  id              String   @id @default(cuid())
  meetingId       String
  studentId       String
  parentName      String
  parentPhone     String?
  teacherName     String
  slotTime        String
  status          String   @default("Booked") // Booked, Attended, Missed, Cancelled
  notes           String?
  createdAt       DateTime @default(now())

  meeting         ParentTeacherMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  student         Student  @relation(fields: [studentId], references: [id])

  @@index([meetingId])
  @@index([studentId])
}

model NoticeBoard {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  content     String
  category    String   @default("General") // General, Academic, Sports, Events, Holiday, Urgent, Exam
  audience    String   @default("All")     // All, Students, Staff, Parents, Teachers
  priority    String   @default("Normal")  // Normal, Important, Urgent
  publishDate DateTime @default(now())
  expiryDate  DateTime?
  isPublished Boolean  @default(true)
  createdBy   String?
  attachments String[] @default([])
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([publishDate])
  @@index([isPublished])
}

model Scholarship {
  id              String   @id @default(cuid())
  schoolId        String
  name            String
  description     String?
  type            String   @default("Merit") // Merit, Need-based, Sports, Government, Disability
  valueType       String   @default("Percentage") // Percentage, Fixed
  value           Float    // percentage or fixed PKR amount
  maxAmount       Float?   // cap for percentage type
  eligibility     String?  // free text criteria
  academicYear    String?
  totalSlots      Int?
  filledSlots     Int      @default(0)
  applicationDeadline DateTime?
  status          String   @default("Open") // Open, Closed, Awarded
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school          School   @relation(fields: [schoolId], references: [id])
  awards          ScholarshipAward[]

  @@index([schoolId])
  @@index([status])
}

model ScholarshipAward {
  id             String   @id @default(cuid())
  scholarshipId  String
  studentId      String
  awardedDate    DateTime @default(now())
  startDate      DateTime
  endDate        DateTime?
  amountAwarded  Float
  status         String   @default("Active") // Active, Expired, Revoked
  remarks        String?
  awardedBy      String?
  createdAt      DateTime @default(now())

  scholarship    Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  student        Student     @relation(fields: [studentId], references: [id])

  @@index([scholarshipId])
  @@index([studentId])
}

model Classroom {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  building    String?
  floor       String?
  capacity    Int      @default(40)
  type        String   @default("Classroom") // Classroom, Lab, Library, Hall, Gym, Office, Staffroom
  facilities  String[] @default([])          // Projector, AC, Whiteboard, Computer, Smart Board
  isAvailable Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([type])
}

model SimpleStore {
  key       String   @id
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

  reviewerId       String?
  appraisalPeriod  String   // e.g. "2024-Q1", "2023-Annual"
  reviewDate       DateTime
  overallRating    Float    // 1-5
  status           String   @default("Draft") // Draft, Submitted, Approved, Acknowledged

  // Rating categories (1-5)
  teachingSkills   Float?
  punctuality      Float?
  teamwork         Float?
  communication    Float?
  subjectKnowledge Float?
  studentEngagement Float?
  professionalism  Float?

  strengths        String?
  areasForImprovement String?
  goals            String?
  reviewerComments String?
  staffComments    String?


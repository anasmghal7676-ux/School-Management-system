// ============================================
// EVENTS & NOTIFICATIONS MODULE
// ============================================

model Event {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  description   String?
  eventType     String   // Holiday, Sports, Cultural, Exam, Meeting, Ceremony
  eventDate     DateTime
  startTime     String?
  endTime       String?
  venue         String?
  organizer     String?
  isHoliday     Boolean  @default(false)
  targetAudience String  // All, Students, Staff, Parents, Specific Class
  targetClassId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([eventDate])
  @@index([eventType])
  @@index([schoolId, eventDate])
  @@index([schoolId, eventType, eventDate])
}

model Announcement {
  id               String   @id @default(cuid())
  schoolId         String
  title            String
  message          String
  announcementType String   // General, Urgent, Academic, Holiday
  targetAudience   String   // All, Class, Section, Students, Parents, Staff
  targetClassId    String?
  targetSectionId  String?
  publishedDate    DateTime
  expiryDate       DateTime?
  isActive         Boolean  @default(true)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, isActive])
  @@index([publishedDate])
  @@index([targetAudience])
  @@index([schoolId, publishedDate, isActive])
}

model Notification {
  id               String   @id @default(cuid())
  userId           String
  title            String
  message          String
  notificationType String   // SMS, Email, Push, In-app
  isRead           Boolean  @default(false)
  sentDate         DateTime @default(now())
  deliveryStatus   String?
  relatedLink      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([sentDate])
  @@index([userId, isRead])
  @@index([userId, sentDate, isRead])
}

